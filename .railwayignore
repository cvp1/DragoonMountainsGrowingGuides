# Files Railway should NOT upload to the build server.
# (Docker .dockerignore only filters the build context AFTER upload;
#  this file controls what gets sent in the first place.)

# Version control — huge, not needed in the image
.git
.gitignore

# IDE / OS cruft
.stfolder
.DS_Store
.claude

# Source material not needed at runtime
revised
*.md
*.log

# Node / Python
node_modules
__pycache__
*.pyc
.env
.env.*

# Raw camera originals — we ship the web-optimized .jpg variants only.
# Each .jpeg is 4-7 MB and collectively they're 42 MB of upload we don't need.
pictures/*.jpeg
pictures/*.JPEG
pictures/*.JPG

